# .env.example — committed template (no real secrets)
# Copy this file to .env.local and fill in real values.

# ---------- MongoDB ----------
# Atlas connection URI.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# <dbname> 가 반드시 들어가야 client.db() 가 인자 없이 동작한다.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/flowtodo?retryWrites=true&w=majority

# ---------- NextAuth ----------
# JWT 서명용 비밀키. 다음 명령으로 생성: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32

# 사이트 URL. 로컬은 http://localhost:3000.
# Vercel 은 자동 감지하지만 명시 권장. NEXTAUTH_URL=https://<your-vercel-domain>.
NEXTAUTH_URL=http://localhost:3000

# ---------- GitHub OAuth ----------
# https://github.com/settings/developers → New OAuth App
# Homepage URL: 위 NEXTAUTH_URL 과 동일.
# Authorization callback URL: ${NEXTAUTH_URL}/api/auth/callback/github
# 로컬용과 prod 용 OAuth App 을 분리해서 등록하는 것을 권장.
GITHUB_ID=REPLACE_WITH_OAUTH_CLIENT_ID
GITHUB_SECRET=REPLACE_WITH_OAUTH_CLIENT_SECRET
